rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Own profile (including when the doc does not exist yet — avoid touching resource.data).
      // Guardian reads dependent: dependent doc has guardianUid == guardian's uid.
      // Dependent reads guardian: own user doc has guardianUid == guardian userId in path.
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (
          exists(/databases/$(database)/documents/users/$(userId)) &&
          'guardianUid' in get(/databases/$(database)/documents/users/$(userId)).data &&
          get(/databases/$(database)/documents/users/$(userId)).data.guardianUid == request.auth.uid
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          'guardianUid' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianUid == userId
        )
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Invite codes: guardians create their mapping; any signed-in user can read to validate a code.
    match /family_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
          && request.resource.data.guardianUid == request.auth.uid
          && request.resource.data.keys().hasAll(['guardianUid', 'createdAt']);
      allow update, delete: if request.auth != null
          && resource.data.guardianUid == request.auth.uid;
    }

    // One document per dependent; created by the dependent to register the link with a guardian.
    match /family_links/{dependentUid} {
      allow read: if request.auth != null && (
        request.auth.uid == dependentUid ||
        (
          exists(/databases/$(database)/documents/family_links/$(dependentUid)) &&
          get(/databases/$(database)/documents/family_links/$(dependentUid)).data.guardianUid == request.auth.uid
        )
      );
      allow create: if request.auth != null
          && request.auth.uid == dependentUid
          && request.resource.data.dependentUid == request.auth.uid
          && request.resource.data.guardianUid is string;
      allow update, delete: if request.auth != null && (
        request.auth.uid == dependentUid ||
        (
          exists(/databases/$(database)/documents/family_links/$(dependentUid)) &&
          get(/databases/$(database)/documents/family_links/$(dependentUid)).data.guardianUid == request.auth.uid
        )
      );
    }

    match /analyses/{docId} {
      allow read, delete, update: if request.auth != null
          && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
    }

    match /medications/{docId} {
      allow read, delete, update: if request.auth != null
          && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
    }

    // Public lab tests catalog.
    // Read allowed to everyone; write allowed to signed-in users (for seeding/admin tooling).
    match /lab_tests/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy name (kept for backward compatibility).
    match /test_definitions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Meta flags for one-time seeding.
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
