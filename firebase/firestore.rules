rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /analyses/{docId} {
      allow read, delete, update: if request.auth != null
          && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
    }

    match /medications/{docId} {
      allow read, delete, update: if request.auth != null
          && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
    }

    // Public lab tests catalog.
    // Read allowed to everyone; write allowed to signed-in users (for seeding/admin tooling).
    match /lab_tests/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy name (kept for backward compatibility).
    match /test_definitions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Meta flags for one-time seeding.
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
